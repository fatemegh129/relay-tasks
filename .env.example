# Sicherheit
# Eine lange zufällige Zeichenkette zum Signieren von JWT-Tokens
SECRET_KEY=

# Datenbank
# Verbindungs-URL zur Datenbank
# Beispiel: postgresql://benutzername:passwort@localhost:5432/relay
DATABASE_URL=

# Frontend
# Die URL, unter der das Frontend läuft
# Beispiel: http://localhost:3000
FRONTEND_URL=

# Backend
# Der Port, auf dem FastAPI läuft
# Beispiel: 8000
BACKEND_PORT=